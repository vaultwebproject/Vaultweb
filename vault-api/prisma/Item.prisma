
enum ItemStatus {
    ACTIVE
    ARCHIVED
}

model Item {
    id             String     @id @unique @default(uuid(7))
    name           String
    submissionData String
    vaultId        String
    vault          Vault      @relation(fields: [vaultId], references: [id])
    status         ItemStatus @default(ACTIVE)
    updatedAt      DateTime   @updatedAt
    createdAt      DateTime   @default(now())
}
