// A user having a UserVault row means they have access to the vault. Vaults are all owned by the org not the user.

enum VaultRole {
    OWNER
    ADMIN
    MEMBER
    VIEWER
}

enum AccessStatus {
    ACTIVE
    REVOKED
}

model UserVault {
    id           String       @id @unique @default(uuid(7))
    userId       String
    vaultId      String
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    vault        Vault        @relation(fields: [vaultId], references: [id])
    vaultRole    VaultRole    @default(VIEWER)
    accessStatus AccessStatus @default(ACTIVE)
    wrappedKey   String
    createdAt    DateTime     @default(now())
    updatedAt    DateTime     @updatedAt

    @@unique([userId, vaultId])
}
